table -Measures
	lineageTag: 167188f1-ee35-489b-9be8-b5da5754b4e7

	measure 'Count of Gender total for Admission Type' =
			
			CALCULATE(
				COUNTA('healthcare_project_3'[Gender]),
				ALL('healthcare_project_3'[Admission Type])
			)
		formatString: 0
		lineageTag: a9445832-2728-49d6-b7b2-e71b8b1791be

		extendedProperty MeasureTemplate =
				{
				  "version": 0,
				  "daxTemplateName": "TotalForAllCategory"
				}

	measure 'Count of Gender average per Admission Type' =
			
			AVERAGEX(
				KEEPFILTERS(VALUES('healthcare_project_3'[Admission Type])),
				CALCULATE(COUNTA('healthcare_project_3'[Gender]))
			)
		lineageTag: ed72b04e-a7bd-44b3-aa71-7a93158610ff

		extendedProperty MeasureTemplate =
				{
				  "version": 0,
				  "daxTemplateName": "AveragePerCategory"
				}

		annotation PBI_FormatHint = {"isGeneralNumber":true}

